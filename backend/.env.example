# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (Supabase Postgres) ──────────────────────────
# DATABASE_URL -> pooled connection (used at runtime, e.g. Supabase "Transaction" pooler on port 6543)
# DIRECT_URL   -> direct connection (used by Prisma Migrate, port 5432)
DATABASE_URL="postgresql://postgres:<password>@<host>:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@<host>:5432/postgres"

# ── JWT ────────────────────────────────────────────────
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ── Google OAuth ───────────────────────────────────────
# OAuth 2.0 Client ID from Google Cloud Console (Web application type)
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# ── Access Control ─────────────────────────────────────
# Only Google accounts on this domain are allowed to log in
ALLOWED_EMAIL_DOMAIN="ceconline.edu"

# ── Dev-only admin override (local development ONLY) ───
# When NODE_ENV=development and the signed-in Google account's email matches
# this value exactly, that account bypasses ALLOWED_EMAIL_DOMAIN and is
# created/updated with the ADMIN role. Ignored completely outside
# NODE_ENV=development — do not set this in staging/production .env files.
# DEV_ADMIN_EMAIL="your_email@gmail.com"

# ── CORS ───────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API (the frontend).
# For local static-file testing this typically includes http://127.0.0.1:5500
# and/or http://localhost:5500 (Live Server / `python -m http.server`).
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500"

# ── AI Service (bundled Python/FastAPI + Gemma via Ollama) ────────────
# Base URL of the ai-service process. It lives at ./ai-service in this repo
# and is run as its own Python process (see ai-service/README.md), but is
# exposed to the frontend only through this backend's /api/v1/ai/chat proxy.
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_TIMEOUT_MS="30000"
